# InfluxDB configuration
# IMPORTANT: rotate any token that has been shared in screenshots or chat.

INFLUX_URL=https://us-west-2-1.api.influxdata.com
INFLUX_TOKEN=replace_with_your_influxdb_token
INFLUX_ORG=your-org
INFLUX_BUCKET=iot-data

APP_SECRET=replace_with_a_long_random_secret
INGEST_API_KEY=replace_with_a_plc_ingest_key

PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# In production, set CLIENT_ORIGIN to your deployed dashboard URL.